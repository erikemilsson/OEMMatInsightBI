/// Row-Level Security Roles for OEMMatInsightBI
/// Implements 6 roles for enterprise security demonstration

role 'Global Executive'
	modelPermission: read

	/// Full access to all data - no filters applied

role 'Regional Manager - Americas'
	modelPermission: read

	tablePermission gold_dim_country = [region] = "Americas"

role 'Regional Manager - Europe'
	modelPermission: read

	tablePermission gold_dim_country = [region] = "Europe"

role 'Regional Manager - Asia-Pacific'
	modelPermission: read

	tablePermission gold_dim_country = [region] = "Asia-Pacific"

role 'Category Manager - Battery Metals'
	modelPermission: read

	tablePermission gold_dim_material = [commodity_group] = "Battery metals"

role 'Category Manager - Base Metals'
	modelPermission: read

	tablePermission gold_dim_material = [commodity_group] = "Base metals"

