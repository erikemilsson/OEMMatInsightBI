table Procurement_Calendar
	lineageTag: 961c7360-62ed-47bb-8923-ae3ac2971d0d

	column Date
		formatString: General Date
		lineageTag: f27d0c13-6ed6-46b0-9d5d-6636f2b9ef1a
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		annotation SummarizationSetBy = Automatic

	column Year
		formatString: 0
		lineageTag: 542f6135-593c-4ea0-824d-d3dc7fb1c56a
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Year]

		annotation SummarizationSetBy = Automatic

	column Month
		formatString: 0
		lineageTag: 2ef56d65-c356-4f34-bdb5-41f4bcf9d679
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Month]

		annotation SummarizationSetBy = Automatic

	column YearMonth
		lineageTag: 014f84bc-44bd-47d6-9268-acd7389e360b
		summarizeBy: none
		isNameInferred
		sourceColumn: [YearMonth]

		annotation SummarizationSetBy = Automatic

	column IsYTD
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: abe97c1a-b316-4f57-804e-0859b144ed98
		summarizeBy: none
		isNameInferred
		sourceColumn: [IsYTD]

		annotation SummarizationSetBy = Automatic

	column IsFullYearBack
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: e30aff84-50b9-4b2f-bb18-df645bc7a941
		summarizeBy: none
		isNameInferred
		sourceColumn: [IsFullYearBack]

		annotation SummarizationSetBy = Automatic

	column IsLastFullYear
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 4334b7bf-f9d6-463c-91c7-bba1a6ee31dd
		summarizeBy: none
		isNameInferred
		sourceColumn: [IsLastFullYear]

		annotation SummarizationSetBy = Automatic

	partition Procurement_Calendar = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(DATE(2020,1,1), TODAY()),
				    "Year", YEAR([Date]),
				    "Month", MONTH([Date]),
				    "YearMonth", FORMAT([Date], "YYYY-MM"),
				    "IsYTD", [Date] <= TODAY(),
				    "IsFullYearBack", [Date] >= TODAY() - 365 && [Date] <= TODAY(),
				    "IsLastFullYear", YEAR([Date]) = YEAR(TODAY()) - 1
				)

	annotation PBI_Id = 49ccd575dc5b4b8c8c36851096fa1441

