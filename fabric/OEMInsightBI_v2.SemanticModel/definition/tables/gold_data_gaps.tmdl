table gold_data_gaps
	lineageTag: d1a2b3c4-e5f6-7890-abcd-ef1234567890
	sourceLineageTag: [dbo].[gold_data_gaps]

	measure 'Procurement Countries with EPI' =
			CALCULATE(
			    DISTINCTCOUNT(gold_data_gaps[country_key]),
			    gold_data_gaps[has_epi_score] = TRUE
			)
		formatString: #,##0
		displayFolder: Data Gaps
		lineageTag: f1a2b3c4-0001-0001-0001-000000000001

	measure 'Procurement Countries without EPI' =
			CALCULATE(
			    DISTINCTCOUNT(gold_data_gaps[country_key]),
			    gold_data_gaps[has_epi_score] = FALSE
			)
		formatString: #,##0
		displayFolder: Data Gaps
		lineageTag: f1a2b3c4-0001-0001-0001-000000000002

	measure 'EPI Country Coverage %' =
			VAR WithEPI = [Procurement Countries with EPI]
			VAR WithoutEPI = [Procurement Countries without EPI]
			VAR Total = WithEPI + WithoutEPI
			RETURN
			    DIVIDE(WithEPI, Total, 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Data Gaps
		lineageTag: f1a2b3c4-0001-0001-0001-000000000003

	measure 'Procurement Spend with EPI' =
			CALCULATE(
			    SUM(gold_data_gaps[spend_eur]),
			    gold_data_gaps[has_epi_score] = TRUE
			)
		formatString: €#,##0
		displayFolder: Data Gaps
		lineageTag: f1a2b3c4-0001-0001-0001-000000000004

	measure 'Procurement Spend without EPI' =
			CALCULATE(
			    SUM(gold_data_gaps[spend_eur]),
			    gold_data_gaps[has_epi_score] = FALSE
			)
		formatString: €#,##0
		displayFolder: Data Gaps
		lineageTag: f1a2b3c4-0001-0001-0001-000000000005

	measure 'EPI Spend Coverage %' =
			VAR SpendWithEPI = [Procurement Spend with EPI]
			VAR TotalSpend = SUM(gold_data_gaps[spend_eur])
			RETURN
			    DIVIDE(SpendWithEPI, TotalSpend, 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Data Gaps
		lineageTag: f1a2b3c4-0001-0001-0001-000000000006

	measure 'Total Procurement Countries' =
			DISTINCTCOUNT(gold_data_gaps[country_key])
		formatString: #,##0
		displayFolder: Data Gaps
		lineageTag: f1a2b3c4-0001-0001-0001-000000000007

	measure 'EPI Gap Summary' =
			VAR WithEPI = [Procurement Countries with EPI]
			VAR Total = [Total Procurement Countries]
			RETURN
			    FORMAT(WithEPI, "#") & " of " & FORMAT(Total, "#") & " countries"
		displayFolder: Data Gaps
		lineageTag: f1a2b3c4-0001-0001-0001-000000000008

	column country_key
		dataType: int64
